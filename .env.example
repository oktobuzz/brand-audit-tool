# ===========================================
# Brand Intelligence Audit Tool - Environment Variables
# ===========================================

# Insight LLM Provider: "groq" (free), "gemini", or "openai"
INSIGHT_PROVIDER=groq

# ============= GROQ (FREE - RECOMMENDED) =============
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============= GEMINI (Optional) =============
# Get API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============= OPENAI (Optional) =============
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============= PERPLEXITY (Optional - for API Mode) =============
# Get API key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
